{
  "config": {
    "project_root": ".",
    "data_dir": "data",
    "json_dir": "data/json",
    "docs_dir": "data/EPOP_documents",
    "artifacts_dir": "artifacts/modernbert_e2e_v2",
    "model_name": "modernbert_staged",
    "encoder_name": "answerdotai/ModernBERT-base",
    "random_seed": 13,
    "max_sentence_distance": 3,
    "max_layout_distance": 6,
    "min_alias_length": 3,
    "learning_rate": 0.08,
    "learning_rate_encoder": 2e-05,
    "epochs": 2,
    "batch_size": 4,
    "train_batch_size": 4,
    "eval_batch_size": 4,
    "gradient_accumulation_steps": 1,
    "l2": 0.0001,
    "weight_decay": 0.01,
    "warmup_ratio": 0.06,
    "early_stopping_patience": 2,
    "feature_cap": 25000,
    "sklearn_c": 1.0,
    "sklearn_max_iter": 400,
    "max_seq_length": 1024,
    "doc_stride": 256,
    "relation_max_seq_length": 768,
    "relation_context_sentence_radius": 1,
    "device": "auto",
    "local_files_only": false,
    "encoder_random_init": false,
    "relation_thresholds": {
      "Located_in": 0.48,
      "Found_on": 0.48,
      "Occurs_on": 0.48,
      "Affects": 0.48,
      "Causes": 0.48,
      "Dispersed_by": 0.48,
      "Transmits": 0.48
    },
    "relation_labels": [
      "Located_in",
      "Found_on",
      "Occurs_on",
      "Affects",
      "Causes",
      "Dispersed_by",
      "Transmits"
    ],
    "mps_device_note": "Designed to stay CPU/NumPy friendly; suitable for M4 Pro notebook workflow."
  }
}